{
  "name": "dfs-electron-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Windows demo for the DFS offline dashboard packaging approach",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "biz.cloudify.dfs-demo",
    "productName": "DFS Dashboard Demo",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "build/icon.png"
    }
  }
}
